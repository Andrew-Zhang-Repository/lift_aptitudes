datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}


enum Gender{
  MALE
  FEMALE
}

enum WeightUnit{
  POUNDS
  KILOGRAMS
}

enum ExperienceLevel{
  BEGINNER
  NOVICE
  INTERMEDIATE
  ADVANCED 
  ELITE
}

model UserRankings {
  user_id        String
  muscle_group   String
  tier           String
  percentile    Int
  color          String
  lift_name      String?    // Add this
  weight         Float?     // Add this
  reps          Int?       // Add this
  estimated_1rm Float?     // Add this
  updated_at     DateTime @updatedAt
  
  @@unique([user_id, muscle_group])
}

model UserMuscleHistory {
  id            Int      @id @default(autoincrement())
  user_id       String
  muscle_group  String
  lift_name     String
  weight        Float
  reps          Int
  estimated_1rm Float
  date          DateTime @default(now())
  
  @@index([user_id, muscle_group])
}


model UserProfiles {
  user_id String @id     
  display_name String @unique
  gender Gender
  bodyweight Float
  bodyweight_unit WeightUnit
  experience_level ExperienceLevel
  updated_at DateTime @updatedAt
  created_at DateTime @default(now())
}

model Lifts{
  id Int @id @default(autoincrement())
  name String @unique
  muscle_group String
  secondary_muscles String[]
  description String
  is_compound Boolean
  is_bodyweight Boolean @default(false)
  standards StrengthStandards[]
  entries UserLiftEntries[]
}

model StrengthStandards {
  id Int @id @default(autoincrement())
  lift_id Int
  lift Lifts @relation(fields: [lift_id], references: [id])
  gender Gender
  bodyweight Float
  experience_level ExperienceLevel
  standard Float
  @@unique([lift_id, gender, bodyweight, experience_level])
}

model UserLiftEntries{
  id Int @id @default(autoincrement())
  user_id String
  lift_id Int
  lift Lifts @relation(fields: [lift_id], references: [id])
  weight Float
  reps Int
  estimated_1rm Float
  date DateTime @default(now())
  created_at DateTime @default(now())
}

